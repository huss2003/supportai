# === LLM Configuration ===
OPENCODE_API_BASE=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# === Security ===
SUPPORTAI_API_KEYS=sk-dev-key-1,sk-dev-key-2
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-in-production

# === Database ===
DATABASE_URL=sqlite:///./data/supportai.db

# === ML Models ===
CLASSIFIER_MODEL=bert-base-uncased
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
FAQ_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_CACHE_DIR=./data/hf_cache

# === FAQ Auto-Answer ===
FAQ_AUTO_ANSWER_THRESHOLD=0.85
FAQ_SUGGEST_THRESHOLD=0.60

# === Session ===
SESSION_EXPIRY_MINUTES=60
MAX_CONTEXT_MESSAGES=50

# === Rate Limiting ===
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60

# === Server ===
CORS_ORIGINS=*
LOG_LEVEL=info
PORT=8000

# === Streamlit ===
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
